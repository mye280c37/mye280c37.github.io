---
import Container from "@/components/container.astro";
import ThemeToggle from "@/components/themetoggle.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";

const { pathname } = Astro.url;
const isHome = pathname === "/" || pathname === "/index.html";

const menuitems = [
  {
    title: "News",
    path: "#news",
  },
  {
    title: "Research Interests",
    path: "#research-interests",
  },
  {
    title: "Publications",
    path: "#publications",
  },
  {
    title: "Projects",
    path: "#projects",
  },
];
---

<div class="sticky top-0 z-50 w-full bg-base backdrop-blur-md">
  <Container>
    <header class="flex flex-col lg:flex-row justify-between items-center my-5">
      <Astronav>
        <div class="flex w-full lg:w-auto items-center justify-between">
          <a href="/#" class="text-xl font-bold">mye280c37</a>
          <div class="block lg:hidden">
            <MenuIcon class="w-4 h-4 text-gray-800" />
          </div>
        </div>
        {
          isHome && (
            <MenuItems class="hidden w-full lg:w-auto mt-2 lg:flex lg:mt-0">
              <ul class="flex flex-col lg:flex-row lg:gap-3">
                {menuitems.map((item, index) => (
                  <>
                    {!item.children && (
                      <li>
                        <a
                          href={item.path}
                          class="nav-link flex lg:px-3 py-2 items-center text-muted hover:text-accent">
                          <span> {item.title}</span>
                        </a>
                      </li>
                    )}
                  </>
                ))}
              </ul>
            </MenuItems>
          )
        }
      </Astronav>
      <div>
        <div class="hidden lg:flex items-center gap-4">
          <ThemeToggle />
        </div>
      </div>
    </header>
  </Container>
</div>

<script>
  // 실행 시점 보장을 위해 DOMContentLoaded 사용
  document.addEventListener("DOMContentLoaded", () => {
    const navLinks = document.querySelectorAll(".nav-link");
    const sections = document.querySelectorAll("section[id]"); // ID가 있는 section들만 감시

    const observerOptions = {
      root: null,
      rootMargin: "-20% 0px -70% 0px", // 화면 중간쯤 왔을 때 인식하도록 범위 조절
      threshold: 0,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute("id");

          // 모든 링크에서 active 제거
          navLinks.forEach((link) => link.classList.remove("active"));

          // 현재 섹션 ID와 href가 일치하는 링크에 active 추가
          const activeLink = document.querySelector(`.nav-link[href="#${id}"]`);
          if (activeLink) {
            activeLink.classList.add("active");
          }
        }
      });
    }, observerOptions);

    sections.forEach((section) => observer.observe(section));
  });
</script>
