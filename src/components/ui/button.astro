---
interface Props {
  href?: string;
  size?: "md" | "lg";
  block?: boolean;
  style?: "outline" | "primary";
  class?: string;
  [x: string]: any;
}

const {
  href,
  size = "md",
  style = "primary",
  block,
  class: className,
  ...rest
} = Astro.props;

const Element = href ? "a" : "button";

const sizes = {
  md: "px-5 py-2.5",
  lg: "px-6 py-3",
};

const styles = {
  outline: "btn-secondary",
  primary: "btn-primary",
};
---

<Element
  href={href}
  {...rest}
  class:list={[
    "rounded-sm text-center transition focus-visible:ring-2 ring-offset-2 ring-gray-200 inline-block", // a 태그일 때를 대비해 inline-block 추가
    block && "w-full",
    sizes[size],
    styles[style],
    className,
  ]}>
  <slot />
</Element>
