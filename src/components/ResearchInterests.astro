---
import { getEntry } from "astro:content";
import { Icon } from "astro-icon/components";

const interestsEntry = await getEntry("interests", "list");
const interests = interestsEntry.data;
---

<div class="mx-auto">
  {
    interests.map((interest) => (
      <div class="accordion-card group">
        <details class="w-full">
          <summary class="flex justify-between items-center p-6 cursor-pointer list-none">
            <h3 class="card-title text-xl md:text-2xl pr-4 leading-tight">
              {interest.title}
            </h3>
            <div class="accordion-arrow transition-transform duration-300">
              <Icon name="bx:bx-chevron-down" class="w-8 h-8" />
            </div>
          </summary>

          <div class="accordion-content px-8 pb-8">
            <ul class="space-y-4 border-l-2 border-accent/20 pl-1">
              {interest.items.map((item) => (
                <li class="relative pl-3 text-lg md:text-xl leading-relaxed text-main/90">
                  <span class="absolute left-[-10px] top-[0.5rem] md:top-[0.65rem] w-2.5 h-2.5 rounded-full bg-accent shadow-[0_0_10px_rgba(var(--color-accent),0.6)] z-10" />
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </details>
      </div>
    ))
  }
</div>
