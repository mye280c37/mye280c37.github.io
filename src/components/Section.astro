---
interface Props {
  title: string;
  id: string;
}

const { title, id } = Astro.props;
---

<section class="py-12 md:py-16 border-t border-muted/10 first:border-0" id={id}>
  <div class="container mx-auto">
    <h2
      class="text-3xl md:text-4xl font-bold text-main mb-10 flex items-center gap-3">
      <span class="w-1.5 h-8 bg-accent rounded-full inline-block"></span>
      {title}
    </h2>

    <div class="section-content">
      <slot />
    </div>
  </div>
</section>
